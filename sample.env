# ─────────────────────────────────────────────────────────────────
#  FsubBot — Single .env, dual bot
#  Copy ke .env lalu isi semua field
# ─────────────────────────────────────────────────────────────────

# ── Telegram API ──────────────────────────────────────────────────
APP_ID=6
API_HASH=eb06d4abfb49dc3eeb1aeb98ae0f581e

# ── Bot 1 ─────────────────────────────────────────────────────────
TG_BOT_TOKEN_1=111111111:AAA-token-bot-pertama
CHANNEL_ID_1=-1001234567890       # channel penyimpanan file
CHANNEL_LOG_1=-1009999999991      # channel log klik (opsional, 0 = nonaktif)

# Force Sub bot 1 (opsional, atau pakai /addfsub)
FORCE_SUB1_1=0

# ── Bot 2 ─────────────────────────────────────────────────────────
TG_BOT_TOKEN_2=222222222:BBB-token-bot-kedua
CHANNEL_ID_2=-1009876543210       # channel penyimpanan file
CHANNEL_LOG_2=-1009999999992      # channel log klik (opsional, 0 = nonaktif)

# Force Sub bot 2 (opsional)
FORCE_SUB1_2=0

# ── Admin & Owner (berlaku untuk kedua bot) ───────────────────────
ADMINS=1234567890
OWNER=yourusername

# ── MongoDB ───────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ── Fitur ─────────────────────────────────────────────────────────
PROTECT_CONTENT=False
BUTTONS_PER_ROW=2
BUTTONS_JOIN_TEXT=ᴊᴏɪɴ
TG_BOT_WORKERS=4
DISABLE_CHANNEL_BUTTON=False

# ── Pesan kustom (kosongkan = pakai default) ──────────────────────
START_MESSAGE=
FORCE_SUB_MESSAGE=
CUSTOM_CAPTION=
